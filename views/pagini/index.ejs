            </dl>
        </section>
        <section id="zona2">
            <h3>Tarife si Servicii Service</h3>
            <div class="tabel-container">
                <table>
                    <caption>Grilă Tarife Service 2026</caption>
                    <thead>
                        <tr>
                            <th>Serviciu</th>
                            <th>Tip Bicicletă</th>
                            <th>Garanție</th>
                            <th>Preț (RON)</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td rowspan="2">Revizie Standard</td>
                            <td>MTB / Road</td>
                            <td>6 luni</td>
                            <td>200</td>
                        </tr>
                        <tr>
                            <td>City / Kids</td>
                            <td>6 luni</td>
                            <td>150</td>
                        </tr>
                        <tr>
                            <td>Aerisire Frâne</td>
                            <td>Hidraulice</td>
                            <td>3 luni</td>
                            <td>80</td>
                        </tr>
                        <tr>
                            <td>Centrat Roată</td>
                            <td>Toate</td>
                            <td>-</td>
                            <td>40</td>
                        </tr>
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="3">Abonament anual (3 revizii incluse)</td>
                            <td>500</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </section>

        <section id="zona3">
            <h3>Evenimente Comunitare</h3>
