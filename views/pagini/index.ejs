        <section id="zona8">
            <h3>Media și Tutoriale</h3>
            
            <div class="math-container">
                <p>Calcul Gear Ratio:</p>
                <math xmlns="http://www.w3.org/1998/Math/MathML" display="block" class="formula-stilizata">
                    <mrow>
                        <mi class="math-result">GR</mi> <mo class="math-op">=</mo>
                        <mfrac>
                            <msub>
                                <mi class="math-top">N</mi>
                                <mi class="math-sub">f</mi>
                            </msub>
                            <msub>
                                <mi class="math-bottom">N</mi>
                                <mi class="math-sub">s</mi>
                            </msub>
                        </mfrac> 
                    </mrow>
                </math>
            </div>

            <figure>
                <picture>
                    <source srcset="./resurse/imagini/bike-300.jpg" media="(max-width: 600px)">
                    <source srcset="./resurse/imagini/bike-800.jpg" media="(max-width: 1024px)">
                    <img src="./resurse/imagini/bike-1200.jpg" alt="Bicicleta Pro">
